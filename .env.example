# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit secrets.
#
# Moving to another machine? The simplest, safest path is to copy your WORKING
# .env.local across verbatim. In particular DATABASE_URL and APP_ENCRYPTION_KEY
# MUST match across machines that share the same database (see notes below).

# --- Database (required) -----------------------------------------------------
# Postgres connection string. Use the Supabase *transaction pooler* host (IPv4,
# port 6543) — the direct db.<ref>.supabase.co host is IPv6-only and times out on
# many machines (especially Windows). Get it from Supabase → Connect → ORM.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require"

# --- Secret encryption (required) --------------------------------------------
# Encrypts provider API keys stored in the DB (AES-256-GCM). 32 bytes, base64.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: use the SAME value on every machine that shares this database, or
# providers saved on one machine can't be decrypted on another.
APP_ENCRYPTION_KEY=""

# --- Clerk auth (optional in dev, required in prod) --------------------------
# Leave BLANK in development: Clerk runs in "keyless mode" and auto-provisions a
# temporary dev instance (sign up with any email, e.g. you+clerk_test@example.com
# with verification code 424242). For persistent accounts / production, create a
# Clerk app (https://dashboard.clerk.com) and paste both keys:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."

# --- AI provider (required to use the chat + agents) -------------------------
# Bring your own — not tied to any vendor. "openai-compatible" works for OpenAI,
# OpenRouter, Together, Groq, Azure, vLLM, Ollama, LM Studio, Google Gemini, etc.
# "anthropic" uses the native Claude API.
AI_PROVIDER="openai-compatible"          # or "anthropic"
AI_BASE_URL="https://api.openai.com/v1"  # required for openai-compatible
AI_API_KEY=""                            # key for that endpoint
AI_MODEL="gpt-4o-mini"                   # model id the endpoint serves
# AI_MODEL_FAST=""                       # optional cheaper model (defaults to AI_MODEL)
# AI_MODEL_SMART=""                      # optional stronger model (defaults to AI_MODEL)
#
# Examples:
#   OpenAI:     AI_BASE_URL="https://api.openai.com/v1"      AI_MODEL="gpt-4o-mini"
#   Gemini:     AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"  AI_MODEL="gemini-2.5-flash"
#   OpenRouter: AI_BASE_URL="https://openrouter.ai/api/v1"   AI_MODEL="anthropic/claude-sonnet-4.6"
#   Groq:       AI_BASE_URL="https://api.groq.com/openai/v1" AI_MODEL="llama-3.3-70b-versatile"
#   Ollama:     AI_BASE_URL="http://localhost:11434/v1"      AI_MODEL="llama3.1"  AI_API_KEY="ollama"
#   Anthropic:  AI_PROVIDER="anthropic"  AI_API_KEY="sk-ant-..."  AI_MODEL="claude-sonnet-4-6"

# --- Optional features -------------------------------------------------------
# Brand memory / RAG embeddings. Without it, the memory features simply no-op.
# AI_EMBED_MODEL="text-embedding-3-small"   # an embeddings model on AI_BASE_URL
# Web research tool (the Audience/strategy agents use it to ground in live facts).
# SEARCH_API_KEY=""
# Protects the /api/cron endpoint for scheduled automations.
# CRON_SECRET=""

# --- Asset storage (optional — Cloudflare R2, later) -------------------------
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""
