# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit secrets.

# --- Database (required) -----------------------------------------------------
# Postgres connection string. Use the Supabase *pooler* host (IPv4) — the direct
# db.<ref>.supabase.co host is IPv6-only and fails on many machines.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Clerk auth (required) ---------------------------------------------------
# From your Clerk application's API keys page (https://dashboard.clerk.com).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# --- AI provider (bring your own) --------------------------------------------
# MarketCall is not tied to any vendor. Point it at whatever model endpoint you
# already use. "openai-compatible" works for OpenAI, OpenRouter, Together, Groq,
# Azure, vLLM, Ollama, LM Studio, etc.; "anthropic" uses the native Claude API.
#
# AI_PROVIDER="openai-compatible"          # or "anthropic"
# AI_BASE_URL="https://api.openai.com/v1"  # required for openai-compatible
# AI_API_KEY=""                            # key for that endpoint
# AI_MODEL="gpt-4o-mini"                   # model id the endpoint serves
# AI_MODEL_FAST=""                         # optional cheaper model (defaults to AI_MODEL)
# AI_MODEL_SMART=""                        # optional stronger model (defaults to AI_MODEL)
#
# Examples:
#   OpenAI:     AI_BASE_URL="https://api.openai.com/v1"      AI_MODEL="gpt-4o-mini"
#   OpenRouter: AI_BASE_URL="https://openrouter.ai/api/v1"   AI_MODEL="anthropic/claude-sonnet-4.6"
#   Groq:       AI_BASE_URL="https://api.groq.com/openai/v1" AI_MODEL="llama-3.3-70b-versatile"
#   Ollama:     AI_BASE_URL="http://localhost:11434/v1"      AI_MODEL="llama3.1"  AI_API_KEY="ollama"
#   Anthropic:  AI_PROVIDER="anthropic"  AI_API_KEY="sk-ant-..."  AI_MODEL="claude-sonnet-4-6"

# --- Asset storage (optional — Cloudflare R2, later) -------------------------
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""
